Package: mfscreen
Type: Package
Title: Model-Free Screening for High-Dimensional Data
Version: 0.1.1
Authors@R: c(
    person("Vincent", "Runge", email = "vincent.runge@univ-evry.fr", role = c("aut", "cre")),
